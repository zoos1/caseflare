---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getAllCases, generateId, getSetting } from '../../lib/db';
import type { Case, Settings } from '../../lib/types';

const env = (Astro.locals as any).runtime?.env;
let cases: Case[] = [];
let settings: Settings = { ai_model: 'claude-sonnet-4-6', extraction_prompt: '', synthesis_prompt: '' };
let dbReady = false;
let dbError = '';
let formSuccess = '';

// Handle POST (new case creation via form)
if (Astro.request.method === 'POST' && env?.DB) {
  try {
    const formData = await Astro.request.formData();
    const id = generateId();
    const now = new Date().toISOString();
    const caseType = (formData.get('case_type') as string) || 'legal_matter';
    await env.DB.prepare(`
      INSERT INTO cases (id, client_name, client_email, firm_name, matter_name, matter_description, gdrive_url, r2_prefix, status, case_type, created_at, updated_at)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?, 'intake', ?, ?, ?)
    `).bind(
      id,
      formData.get('client_name') as string,
      (formData.get('client_email') as string) || null,
      (formData.get('firm_name') as string) || null,
      formData.get('matter_name') as string,
      (formData.get('matter_description') as string) || null,
      (formData.get('gdrive_url') as string) || null,
      `${id}/`,
      caseType,
      now, now
    ).run();
    return Astro.redirect('/admin?created=' + id);
  } catch (e: any) {
    dbError = 'Failed to create case: ' + e.message;
  }
}

// Load data
if (env?.DB) {
  try {
    const result = await getAllCases(env.DB);
    cases = (result.results || []) as unknown as Case[];
    const [model, extraction, synthesis] = await Promise.all([
      getSetting(env.DB, 'ai_model'),
      getSetting(env.DB, 'extraction_prompt'),
      getSetting(env.DB, 'synthesis_prompt'),
    ]);
    settings = {
      ai_model: model || 'claude-sonnet-4-6',
      extraction_prompt: extraction || '',
      synthesis_prompt: synthesis || '',
    };
    dbReady = true;
  } catch (e: any) {
    dbError = e.message;
  }
} else {
  dbError = 'D1 database binding not available.';
}

const url = new URL(Astro.request.url);
if (url.searchParams.has('created')) {
  formSuccess = `Case ${url.searchParams.get('created')} created successfully.`;
}

// Stats
const totalCases = cases.length;
const processingCases = cases.filter(c => c.status === 'processing').length;
const completeCases = cases.filter(c => c.status === 'complete').length;
const totalEvents = cases.reduce((sum, c) => sum + (c.event_count || 0), 0);

const statusColors: Record<string, string> = {
  intake: 'bg-slate-700 text-slate-300',
  processing: 'bg-yellow-900/60 text-yellow-300',
  complete: 'bg-green-900/60 text-green-300',
  error: 'bg-red-900/60 text-red-300',
};

const now = new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title="CaseFlare Admin | Superflare">
  <div class="min-h-screen bg-slate-950">
    <!-- Header -->
    <header class="border-b border-white/8 bg-slate-950/80 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold text-sm">CF</div>
          <h1 class="text-xl font-semibold text-white">CaseFlare <span class="text-brand-400 font-normal text-sm">Admin</span></h1>
        </div>
        <div class="flex items-center gap-4 text-sm text-slate-400">
          <span>{now}</span>
          <div class="flex items-center gap-2">
            <span class={`w-2 h-2 rounded-full ${dbReady ? 'bg-green-400' : 'bg-red-400'}`}></span>
            <span>{dbReady ? 'System Ready' : 'DB Unavailable'}</span>
          </div>
          <a href="/api/auth/logout" class="text-xs text-slate-500 hover:text-slate-300 transition-colors ml-2">Sign Out</a>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-8 space-y-8">
      <!-- DB Error Banner -->
      {!dbReady && (
        <div class="bg-red-950/50 border border-red-800/50 rounded-2xl p-6">
          <h2 class="text-red-300 font-semibold text-lg mb-2">Database Not Initialized</h2>
          <p class="text-red-400/80 mb-4">{dbError}</p>
          <div class="bg-slate-900 rounded-xl p-4 font-mono text-sm text-slate-300">
            <p class="text-slate-500 mb-1"># Initialize the local D1 database:</p>
            <p>bun run db:init</p>
            <p class="text-slate-500 mt-3 mb-1"># For remote (production) database:</p>
            <p>wrangler d1 create caseflare-db</p>
            <p>bun run db:init:remote</p>
          </div>
        </div>
      )}

      <!-- Success Banner -->
      {formSuccess && (
        <div class="bg-green-950/50 border border-green-800/50 rounded-2xl p-4 text-green-300">
          {formSuccess}
        </div>
      )}

      <!-- Stats Row -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="bg-slate-900/50 border border-white/8 rounded-2xl p-6">
          <p class="text-sm text-slate-400 mb-1">Total Cases</p>
          <p class="text-3xl font-bold text-white">{totalCases}</p>
        </div>
        <div class="bg-slate-900/50 border border-white/8 rounded-2xl p-6">
          <p class="text-sm text-slate-400 mb-1">Processing</p>
          <p class="text-3xl font-bold text-yellow-400">{processingCases}</p>
        </div>
        <div class="bg-slate-900/50 border border-white/8 rounded-2xl p-6">
          <p class="text-sm text-slate-400 mb-1">Complete</p>
          <p class="text-3xl font-bold text-green-400">{completeCases}</p>
        </div>
        <div class="bg-slate-900/50 border border-white/8 rounded-2xl p-6">
          <p class="text-sm text-slate-400 mb-1">Total Events</p>
          <p class="text-3xl font-bold text-brand-400">{totalEvents}</p>
        </div>
      </div>

      <!-- Main Content Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Cases Table (2/3 width) -->
        <div class="lg:col-span-2">
          <div class="bg-slate-900/50 border border-white/8 rounded-2xl overflow-hidden">
            <div class="px-6 py-4 border-b border-white/8">
              <h2 class="text-lg font-semibold text-white">Open Cases</h2>
            </div>
            {cases.length === 0 ? (
              <div class="p-12 text-center text-slate-500">
                <p class="text-lg mb-2">No cases yet</p>
                <p class="text-sm">Create your first case using the form.</p>
              </div>
            ) : (
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="text-left text-slate-400 text-xs uppercase tracking-wider">
                      <th class="px-6 py-3">Case ID</th>
                      <th class="px-6 py-3">Client / Firm</th>
                      <th class="px-6 py-3">Matter</th>
                      <th class="px-6 py-3">Type</th>
                      <th class="px-6 py-3">Status</th>
                      <th class="px-6 py-3 text-center">Docs</th>
                      <th class="px-6 py-3 text-center">Events</th>
                      <th class="px-6 py-3">Created</th>
                      <th class="px-6 py-3">Client Portal</th>
                      <th class="px-6 py-3">Actions</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-white/5">
                    {cases.map((c) => (
                      <tr class="hover:bg-white/3 group" data-case-id={c.id}>
                        <td class="px-6 py-4">
                          <a href={(c as any).case_type === 'ma_due_diligence' ? `/report/${c.id}` : `/case/${c.id}`} class="font-mono text-brand-400 hover:text-brand-300 text-xs">{c.id}</a>
                        </td>
                        <td class="px-6 py-4">
                          <div class="text-white">{c.client_name}</div>
                          {c.firm_name && <div class="text-slate-500 text-xs">{c.firm_name}</div>}
                        </td>
                        <td class="px-6 py-4 text-slate-300 max-w-[200px] truncate">{c.matter_name}</td>
                        <td class="px-6 py-4">
                          {(c as any).case_type === 'ma_due_diligence' ? (
                            <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-900/60 text-green-300">Due Diligence</span>
                          ) : (
                            <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-900/60 text-blue-300">Timeline</span>
                          )}
                        </td>
                        <td class="px-6 py-4">
                          <span class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-medium ${statusColors[c.status] || statusColors.intake}`}>
                            {c.status}
                          </span>
                        </td>
                        <td class="px-6 py-4 text-center text-slate-400">{c.doc_count}</td>
                        <td class="px-6 py-4 text-center text-slate-400">{c.event_count}</td>
                        <td class="px-6 py-4 text-slate-500 text-xs">{new Date(c.created_at).toLocaleDateString()}</td>
                        <td class="px-6 py-4">
                          <div class="flex items-center gap-2" data-pin-cell={c.id}>
                            {c.client_pin ? (
                              <>
                                <span class="font-mono text-xs text-green-400" data-pin-display={c.id}>{c.client_pin}</span>
                                <button data-copy-creds={c.id} data-email={c.client_email || ''} data-pin={c.client_pin} class="text-xs text-brand-400 hover:text-brand-300" title="Copy portal credentials">Copy</button>
                              </>
                            ) : (
                              <button data-gen-pin={c.id} class="text-xs text-brand-400 hover:text-brand-300 whitespace-nowrap">Generate PIN</button>
                            )}
                          </div>
                        </td>
                        <td class="px-6 py-4">
                          <div class="flex items-center gap-2">
                            <button data-upload={c.id} class="text-xs text-brand-400 hover:text-brand-300 whitespace-nowrap" title="Upload documents">Upload</button>
                            <a href={(c as any).case_type === 'ma_due_diligence' ? `/report/${c.id}` : `/case/${c.id}`} class="text-xs text-brand-400 hover:text-brand-300 whitespace-nowrap">View</a>
                            <button data-process={c.id} class="text-xs text-yellow-400 hover:text-yellow-300 whitespace-nowrap disabled:opacity-40 disabled:cursor-not-allowed" disabled={c.doc_count === 0 || c.status === 'processing'}>Process</button>
                            <button data-delete={c.id} class="text-xs text-red-400 hover:text-red-300 whitespace-nowrap">Delete</button>
                          </div>
                        </td>
                      </tr>
                      <tr class="hidden" data-detail={c.id}>
                        <td colspan="10" class="px-6 py-4 bg-slate-900/30">
                          <div class="space-y-4">
                            <div class="grid grid-cols-2 gap-4 text-xs">
                              {c.client_email && <div><span class="text-slate-500">Email:</span> <span class="text-slate-300">{c.client_email}</span></div>}
                              {c.gdrive_url && <div><span class="text-slate-500">Drive:</span> <a href={c.gdrive_url} target="_blank" class="text-brand-400 hover:underline">{c.gdrive_url}</a></div>}
                              <div><span class="text-slate-500">R2 Path:</span> <span class="font-mono text-slate-300">caseflare-docs/{c.id}/</span></div>
                            </div>

                            <!-- Upload Zone -->
                            <div class="upload-zone" data-upload-zone={c.id}>
                              <div class="border-2 border-dashed border-white/10 rounded-xl p-6 text-center hover:border-brand-600/50 transition-colors cursor-pointer" data-dropzone={c.id}>
                                <svg class="w-8 h-8 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                                </svg>
                                <p class="text-sm text-slate-400 mb-1">Drop files here or click to browse</p>
                                <p class="text-xs text-slate-600">PDF, DOCX, DOC, TXT, EML, MSG, PNG, JPG</p>
                                <input type="file" class="hidden" data-file-input={c.id} multiple accept=".pdf,.docx,.doc,.txt,.eml,.msg,.png,.jpg,.jpeg" />
                              </div>
                              <div class="mt-3 hidden" data-upload-progress={c.id}>
                                <div class="flex items-center gap-3">
                                  <div class="flex-1 bg-slate-800 rounded-full h-1.5 overflow-hidden">
                                    <div class="bg-brand-600 h-full rounded-full transition-all duration-300" data-progress-bar={c.id} style="width: 0%"></div>
                                  </div>
                                  <span class="text-xs text-slate-400" data-progress-text={c.id}>Uploading...</span>
                                </div>
                              </div>
                              <div class="mt-3 space-y-1" data-file-list={c.id}></div>
                            </div>

                            {c.processing_log && (
                              <div>
                                <span class="text-xs text-slate-500">Processing Log:</span>
                                <pre class="mt-1 bg-slate-950 rounded-lg p-3 text-xs text-slate-400 whitespace-pre-wrap max-h-48 overflow-y-auto">{c.processing_log}</pre>
                              </div>
                            )}
                          </div>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        </div>

        <!-- New Case Form (1/3 width) -->
        <div>
          <div class="bg-slate-900/50 border border-white/8 rounded-2xl p-6">
            <h2 class="text-lg font-semibold text-white mb-6">New Case</h2>
            <form method="POST" class="space-y-4">
              <div>
                <label for="client_name" class="block text-sm text-slate-400 mb-1">Client Name *</label>
                <input type="text" name="client_name" id="client_name" required
                  class="w-full bg-slate-800 border border-white/10 rounded-xl px-4 py-2.5 text-white text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent placeholder-slate-500"
                  placeholder="John Doe" />
              </div>
              <div>
                <label for="client_email" class="block text-sm text-slate-400 mb-1">Client Email</label>
                <input type="email" name="client_email" id="client_email"
                  class="w-full bg-slate-800 border border-white/10 rounded-xl px-4 py-2.5 text-white text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent placeholder-slate-500"
                  placeholder="john@example.com" />
              </div>
              <div>
                <label for="firm_name" class="block text-sm text-slate-400 mb-1">Firm Name</label>
                <input type="text" name="firm_name" id="firm_name"
                  class="w-full bg-slate-800 border border-white/10 rounded-xl px-4 py-2.5 text-white text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent placeholder-slate-500"
                  placeholder="Smith & Associates" />
              </div>
              <div>
                <label for="matter_name" class="block text-sm text-slate-400 mb-1">Matter Name *</label>
                <input type="text" name="matter_name" id="matter_name" required
                  class="w-full bg-slate-800 border border-white/10 rounded-xl px-4 py-2.5 text-white text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent placeholder-slate-500"
                  placeholder="Estate of Williams - Probate" />
              </div>
              <div>
                <label for="matter_description" class="block text-sm text-slate-400 mb-1">Matter Description</label>
                <textarea name="matter_description" id="matter_description" rows="3"
                  class="w-full bg-slate-800 border border-white/10 rounded-xl px-4 py-2.5 text-white text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent placeholder-slate-500 resize-none"
                  placeholder="Brief description of the legal matter..."></textarea>
              </div>
              <div>
                <label for="gdrive_url" class="block text-sm text-slate-400 mb-1">Google Drive URL</label>
                <input type="url" name="gdrive_url" id="gdrive_url"
                  class="w-full bg-slate-800 border border-white/10 rounded-xl px-4 py-2.5 text-white text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent placeholder-slate-500"
                  placeholder="https://drive.google.com/drive/folders/..." />
              </div>
              <div>
                <label class="block text-sm text-slate-400 mb-2">Case Type</label>
                <div class="space-y-2">
                  <label class="flex items-center gap-3 cursor-pointer bg-slate-800 border border-white/10 rounded-xl px-4 py-3 hover:border-white/20 transition-colors has-[:checked]:border-brand-600/50 has-[:checked]:bg-brand-950/30">
                    <input type="radio" name="case_type" value="legal_matter" checked class="text-brand-600 focus:ring-brand-600 bg-slate-700 border-slate-600" />
                    <div>
                      <div class="text-sm text-white font-medium">Legal Matter Timeline</div>
                      <div class="text-xs text-slate-500">Chronological event extraction from legal documents</div>
                    </div>
                  </label>
                  <label class="flex items-center gap-3 cursor-pointer bg-slate-800 border border-white/10 rounded-xl px-4 py-3 hover:border-white/20 transition-colors has-[:checked]:border-green-600/50 has-[:checked]:bg-green-950/20">
                    <input type="radio" name="case_type" value="ma_due_diligence" class="text-green-600 focus:ring-green-600 bg-slate-700 border-slate-600" />
                    <div>
                      <div class="text-sm text-white font-medium">M&A Due Diligence Report</div>
                      <div class="text-xs text-slate-500">Deal intelligence analysis for acquisitions</div>
                    </div>
                  </label>
                </div>
              </div>
              <button type="submit"
                class="w-full bg-brand-600 hover:bg-brand-500 text-white font-medium py-2.5 px-4 rounded-xl transition-colors text-sm">
                Create Case
              </button>
            </form>
          </div>
        </div>
      </div>

      <!-- System Settings -->
      <div class="bg-slate-900/50 border border-white/8 rounded-2xl overflow-hidden">
        <div class="px-6 py-4 border-b border-white/8 flex items-center justify-between">
          <h2 class="text-lg font-semibold text-white">System Settings</h2>
          <span id="settings-status" class="text-xs text-slate-500"></span>
        </div>
        <div class="p-6 space-y-6">
          <!-- AI Model -->
          <div>
            <label for="ai_model" class="block text-sm text-slate-400 mb-2">AI Model</label>
            <select id="ai_model"
              class="bg-slate-800 border border-white/10 rounded-xl px-4 py-2.5 text-white text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent w-full max-w-md">
              <option value="claude-opus-4-6" selected={settings.ai_model === 'claude-opus-4-6'}>claude-opus-4-6</option>
              <option value="claude-sonnet-4-6" selected={settings.ai_model === 'claude-sonnet-4-6'}>claude-sonnet-4-6</option>
              <option value="claude-haiku-4-5-20251001" selected={settings.ai_model === 'claude-haiku-4-5-20251001'}>claude-haiku-4-5-20251001</option>
            </select>
          </div>

          <!-- Extraction Prompt -->
          <div>
            <label for="extraction_prompt" class="block text-sm text-slate-400 mb-2">Extraction Prompt</label>
            <textarea id="extraction_prompt" rows="5"
              class="w-full bg-slate-800 border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent font-mono resize-y">{settings.extraction_prompt}</textarea>
          </div>

          <!-- Synthesis Prompt -->
          <div>
            <label for="synthesis_prompt" class="block text-sm text-slate-400 mb-2">Synthesis Prompt</label>
            <textarea id="synthesis_prompt" rows="5"
              class="w-full bg-slate-800 border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent font-mono resize-y">{settings.synthesis_prompt}</textarea>
          </div>

          <!-- Save Button -->
          <button id="save-settings"
            class="bg-brand-600 hover:bg-brand-500 text-white font-medium py-2.5 px-6 rounded-xl transition-colors text-sm">
            Save Settings
          </button>

          <!-- System File Paths -->
          <div class="mt-8">
            <h3 class="text-sm text-slate-400 mb-3">System File Paths</h3>
            <div class="bg-slate-950 border border-white/5 rounded-xl p-5 font-mono text-xs space-y-2">
              <div class="flex"><span class="text-slate-500 w-40 shrink-0">App directory:</span> <span class="text-slate-300">/Users/stu/caseflare</span></div>
              <div class="flex"><span class="text-slate-500 w-40 shrink-0">Build output:</span> <span class="text-slate-300">/Users/stu/caseflare/dist</span></div>
              <div class="flex"><span class="text-slate-500 w-40 shrink-0">Wrangler config:</span> <span class="text-slate-300">/Users/stu/caseflare/wrangler.toml</span></div>
              <div class="flex"><span class="text-slate-500 w-40 shrink-0">R2 Bucket:</span> <span class="text-slate-300">caseflare-docs</span></div>
              <div class="flex"><span class="text-slate-500 w-40 shrink-0">D1 Database:</span> <span class="text-slate-300">caseflare-db</span></div>
              <div class="flex"><span class="text-slate-500 w-40 shrink-0">Case files pattern:</span> <span class="text-slate-300">caseflare-docs/&#123;case_id&#125;/</span></div>
              <div class="mt-3 pt-3 border-t border-white/5 text-slate-500 leading-relaxed">
                Case files are stored in R2 at path: caseflare-docs/&#123;case_id&#125;/ — access via
                Cloudflare dashboard or <span class="text-slate-400">wrangler r2 object list caseflare-docs --prefix=&#123;case_id&#125;/</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Upload Modal -->
  <div id="upload-modal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-modal-backdrop></div>
    <div class="absolute inset-0 flex items-center justify-center p-6">
      <div class="bg-slate-900 border border-white/10 rounded-2xl w-full max-w-lg shadow-2xl">
        <div class="px-6 py-4 border-b border-white/8 flex items-center justify-between">
          <h3 class="text-base font-semibold text-white">Upload Documents</h3>
          <button data-modal-close class="text-slate-400 hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <div class="p-6">
          <div id="modal-dropzone" class="border-2 border-dashed border-white/10 rounded-xl p-8 text-center hover:border-brand-600/50 transition-colors cursor-pointer">
            <svg class="w-10 h-10 mx-auto mb-4 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
            </svg>
            <p class="text-sm text-slate-300 mb-1">Drop files here or click to browse</p>
            <p class="text-xs text-slate-500">PDF, DOCX, DOC, TXT, EML, MSG, PNG, JPG</p>
            <input type="file" id="modal-file-input" class="hidden" multiple accept=".pdf,.docx,.doc,.txt,.eml,.msg,.png,.jpg,.jpeg" />
          </div>
          <div id="modal-progress" class="mt-4 hidden">
            <div class="flex items-center gap-3">
              <div class="flex-1 bg-slate-800 rounded-full h-2 overflow-hidden">
                <div id="modal-progress-bar" class="bg-brand-600 h-full rounded-full transition-all duration-300" style="width: 0%"></div>
              </div>
              <span id="modal-progress-text" class="text-xs text-slate-400 min-w-[80px] text-right">Uploading...</span>
            </div>
          </div>
          <div id="modal-file-list" class="mt-4 space-y-1 max-h-48 overflow-y-auto"></div>
          <div id="modal-result" class="mt-4 hidden"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ─── Upload Modal Logic ──────────────────────────────────────────────────
    const modal = document.getElementById('upload-modal');
    const modalDropzone = document.getElementById('modal-dropzone');
    const modalFileInput = document.getElementById('modal-file-input') as HTMLInputElement;
    const modalProgress = document.getElementById('modal-progress');
    const modalProgressBar = document.getElementById('modal-progress-bar');
    const modalProgressText = document.getElementById('modal-progress-text');
    const modalFileList = document.getElementById('modal-file-list');
    const modalResult = document.getElementById('modal-result');
    let currentUploadCaseId: string | null = null;

    function openUploadModal(caseId: string) {
      currentUploadCaseId = caseId;
      if (modal) modal.classList.remove('hidden');
      if (modalFileList) modalFileList.innerHTML = '';
      if (modalResult) { modalResult.classList.add('hidden'); modalResult.innerHTML = ''; }
      if (modalProgress) modalProgress.classList.add('hidden');
      if (modalProgressBar) modalProgressBar.style.width = '0%';
      // Load existing files
      loadFileList(caseId);
    }

    function closeUploadModal() {
      if (modal) modal.classList.add('hidden');
      currentUploadCaseId = null;
    }

    // Close on backdrop click or close button
    modal?.querySelector('[data-modal-backdrop]')?.addEventListener('click', closeUploadModal);
    modal?.querySelector('[data-modal-close]')?.addEventListener('click', closeUploadModal);

    // Open from table Upload button
    document.querySelectorAll<HTMLButtonElement>('button[data-upload]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = btn.dataset.upload;
        if (id) openUploadModal(id);
      });
    });

    // Dropzone click
    modalDropzone?.addEventListener('click', () => modalFileInput?.click());

    // Dropzone drag events
    if (modalDropzone) {
      modalDropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        modalDropzone.classList.add('border-brand-600/50', 'bg-brand-950/20');
      });
      modalDropzone.addEventListener('dragleave', () => {
        modalDropzone.classList.remove('border-brand-600/50', 'bg-brand-950/20');
      });
      modalDropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        modalDropzone.classList.remove('border-brand-600/50', 'bg-brand-950/20');
        const files = e.dataTransfer?.files;
        if (files && files.length > 0 && currentUploadCaseId) {
          uploadFiles(currentUploadCaseId, Array.from(files));
        }
      });
    }

    // File input change
    modalFileInput?.addEventListener('change', () => {
      const files = modalFileInput.files;
      if (files && files.length > 0 && currentUploadCaseId) {
        uploadFiles(currentUploadCaseId, Array.from(files));
      }
      modalFileInput.value = '';
    });

    async function uploadFiles(caseId: string, files: File[]) {
      if (modalProgress) modalProgress.classList.remove('hidden');
      if (modalProgressBar) modalProgressBar.style.width = '0%';
      if (modalProgressText) modalProgressText.textContent = `Uploading ${files.length} file(s)...`;
      if (modalResult) { modalResult.classList.add('hidden'); modalResult.innerHTML = ''; }

      const formData = new FormData();
      for (const file of files) {
        formData.append('files', file);
      }

      try {
        const res = await fetch(`/api/upload/${caseId}`, {
          method: 'POST',
          body: formData,
        });

        if (modalProgressBar) modalProgressBar.style.width = '100%';

        const data = await res.json();

        if (data.ok) {
          if (modalProgressText) modalProgressText.textContent = 'Done!';
          if (modalResult) {
            modalResult.classList.remove('hidden');
            modalResult.innerHTML = `<div class="bg-green-950/50 border border-green-800/50 rounded-xl p-3 text-xs text-green-300">Uploaded ${data.uploaded.length} file(s). Total docs: ${data.totalDocs}</div>`;
          }
          // Refresh file list
          loadFileList(caseId);
          // Update doc count in table
          const docCountCell = document.querySelector(`tr[data-case-id="${caseId}"] td:nth-child(5)`);
          if (docCountCell) docCountCell.textContent = String(data.totalDocs);
          // Enable process button
          const processBtn = document.querySelector(`button[data-process="${caseId}"]`) as HTMLButtonElement;
          if (processBtn && data.totalDocs > 0) processBtn.disabled = false;
        } else {
          throw new Error(data.error || 'Upload failed');
        }
      } catch (err: any) {
        if (modalProgressText) modalProgressText.textContent = 'Error';
        if (modalResult) {
          modalResult.classList.remove('hidden');
          modalResult.innerHTML = `<div class="bg-red-950/50 border border-red-800/50 rounded-xl p-3 text-xs text-red-300">${err.message}</div>`;
        }
      }
    }

    async function loadFileList(caseId: string) {
      if (!modalFileList) return;
      try {
        const res = await fetch(`/api/upload/${caseId}`);
        const data = await res.json();
        if (data.files && data.files.length > 0) {
          modalFileList.innerHTML = data.files.map((f: any) => `
            <div class="flex items-center justify-between bg-slate-800/50 rounded-lg px-3 py-2 text-xs">
              <div class="flex items-center gap-2 min-w-0">
                <svg class="w-3.5 h-3.5 text-slate-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <span class="text-slate-300 truncate">${f.name}</span>
              </div>
              <span class="text-slate-500 shrink-0 ml-2">${formatFileSize(f.size)}</span>
            </div>
          `).join('');
        } else {
          modalFileList.innerHTML = '<p class="text-xs text-slate-600 text-center py-2">No files uploaded yet</p>';
        }
      } catch {
        // Silently fail — not critical
      }
    }

    function formatFileSize(bytes: number): string {
      if (bytes === 0) return '0 B';
      const k = 1024;
      const sizes = ['B', 'KB', 'MB', 'GB'];
      const i = Math.floor(Math.log(bytes) / Math.log(k));
      return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
    }

    // ─── Row expand/collapse ─────────────────────────────────────────────────
    document.querySelectorAll<HTMLTableRowElement>('tr[data-case-id]').forEach(row => {
      row.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('a') || target.closest('button')) return;
        const id = row.dataset.caseId;
        const detail = document.querySelector<HTMLTableRowElement>(`tr[data-detail="${id}"]`);
        if (detail) detail.classList.toggle('hidden');
      });
    });

    // ─── Process button ──────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('button[data-process]').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = btn.dataset.process;
        if (btn.disabled) return;
        if (!confirm(`Process case ${id}? This will analyze all uploaded documents with Claude AI.`)) return;
        btn.textContent = 'Starting...';
        btn.disabled = true;
        try {
          const res = await fetch(`/api/process/${id}`, { method: 'POST' });
          if (res.ok) {
            // Poll for completion
            btn.textContent = 'Processing...';
            const statusCell = btn.closest('tr')?.querySelector('td:nth-child(4) span');
            if (statusCell) {
              statusCell.className = 'inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-900/60 text-yellow-300';
              statusCell.textContent = 'processing';
            }
            // Reload after a short delay to show updated status
            setTimeout(() => window.location.reload(), 2000);
          } else {
            const data = await res.json();
            btn.textContent = 'Error';
            alert('Processing failed: ' + (data.error || 'Unknown error'));
            setTimeout(() => { btn.textContent = 'Process'; btn.disabled = false; }, 3000);
          }
        } catch {
          btn.textContent = 'Error';
          setTimeout(() => { btn.textContent = 'Process'; btn.disabled = false; }, 3000);
        }
      });
    });

    // ─── Delete button ───────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('button[data-delete]').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = btn.dataset.delete;
        if (!confirm(`Delete case ${id}? This cannot be undone.`)) return;
        btn.textContent = 'Deleting...';
        btn.disabled = true;
        try {
          const res = await fetch(`/api/cases/${id}`, { method: 'DELETE' });
          if (res.ok) {
            window.location.reload();
          } else {
            btn.textContent = 'Error';
          }
        } catch {
          btn.textContent = 'Error';
        }
      });
    });

    // ─── Settings save ───────────────────────────────────────────────────────
    const saveBtn = document.getElementById('save-settings');
    const statusEl = document.getElementById('settings-status');
    if (saveBtn) {
      saveBtn.addEventListener('click', async () => {
        saveBtn.textContent = 'Saving...';
        (saveBtn as HTMLButtonElement).disabled = true;
        try {
          const body = {
            ai_model: (document.getElementById('ai_model') as HTMLSelectElement).value,
            extraction_prompt: (document.getElementById('extraction_prompt') as HTMLTextAreaElement).value,
            synthesis_prompt: (document.getElementById('synthesis_prompt') as HTMLTextAreaElement).value,
          };
          const res = await fetch('/api/settings', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          if (res.ok) {
            if (statusEl) statusEl.textContent = 'Settings saved';
            setTimeout(() => { if (statusEl) statusEl.textContent = ''; }, 3000);
          } else {
            if (statusEl) statusEl.textContent = 'Failed to save';
          }
        } catch {
          if (statusEl) statusEl.textContent = 'Error saving settings';
        } finally {
          saveBtn.textContent = 'Save Settings';
          (saveBtn as HTMLButtonElement).disabled = false;
        }
      });
    }

    // ─── Generate PIN ─────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('button[data-gen-pin]').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = btn.dataset.genPin;
        if (!id) return;
        btn.textContent = 'Generating...';
        btn.disabled = true;
        try {
          const res = await fetch(`/api/cases/${id}/pin`, { method: 'POST' });
          const data = await res.json();
          if (data.pin) {
            const cell = document.querySelector(`[data-pin-cell="${id}"]`);
            if (cell) {
              // Find the case row to get client_email
              const row = document.querySelector(`tr[data-case-id="${id}"]`);
              const emailEl = row?.querySelector('td:nth-child(2) div:first-child');
              const clientEmail = btn.closest('tr')?.querySelector('[data-email]')?.getAttribute('data-email') || '';
              cell.innerHTML = `
                <span class="font-mono text-xs text-green-400" data-pin-display="${id}">${data.pin}</span>
                <button data-copy-creds="${id}" data-email="" data-pin="${data.pin}" class="text-xs text-brand-400 hover:text-brand-300" title="Copy portal credentials">Copy</button>
              `;
              // Attach copy handler to new button
              attachCopyHandler(cell.querySelector(`[data-copy-creds="${id}"]`) as HTMLButtonElement);
            }
          } else {
            btn.textContent = 'Error';
            setTimeout(() => { btn.textContent = 'Generate PIN'; btn.disabled = false; }, 2000);
          }
        } catch {
          btn.textContent = 'Error';
          setTimeout(() => { btn.textContent = 'Generate PIN'; btn.disabled = false; }, 2000);
        }
      });
    });

    // ─── Copy Credentials ─────────────────────────────────────────────────
    function attachCopyHandler(btn: HTMLButtonElement | null) {
      if (!btn) return;
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const pin = btn.dataset.pin || '';
        const email = btn.dataset.email || '';
        const portalUrl = 'https://app.superflare.ai/portal';
        let text = `Portal: ${portalUrl}\nPIN: ${pin}`;
        if (email) text = `Email: ${email}\n${text}`;
        try {
          await navigator.clipboard.writeText(text);
          const orig = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = orig; }, 2000);
        } catch {
          // Fallback
          btn.textContent = 'Failed';
          setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
        }
      });
    }

    // Attach to existing copy buttons
    document.querySelectorAll<HTMLButtonElement>('button[data-copy-creds]').forEach(attachCopyHandler);
  </script>
</Layout>
