---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { getCaseById, getEventsByCase } from '../../../lib/db';
import type { Case, Event } from '../../../lib/types';

const { id } = Astro.params;
const env = (Astro.locals as any).runtime?.env;

if (!env?.DB) {
  return new Response('Service unavailable', { status: 503 });
}

// The middleware already verified the session and case_id match.
// Double-check: if locals.client is missing, redirect.
const clientSession = (Astro.locals as any).client;
if (!clientSession || clientSession.case_id !== id) {
  return Astro.redirect('/portal?error=unauthorized');
}

const caseData = await getCaseById(env.DB, id!) as Case | null;
if (!caseData) {
  return new Response('Not found', { status: 404 });
}

const eventsResult = await getEventsByCase(env.DB, id!);
const events = (eventsResult.results || []) as unknown as Event[];

// Compute date range
let dateRange = '';
const datedEvents = events.filter(e => e.event_date);
if (datedEvents.length > 0) {
  const first = datedEvents[0].event_date;
  const last = datedEvents[datedEvents.length - 1].event_date;
  dateRange = first === last ? first! : `${first} - ${last}`;
}

const tagColors: Record<string, string> = {
  filing: 'bg-blue-900/60 text-blue-300',
  communication: 'bg-slate-700 text-slate-300',
  violation: 'bg-red-900/60 text-red-300',
  agreement: 'bg-green-900/60 text-green-300',
  'court-order': 'bg-purple-900/60 text-purple-300',
  deadline: 'bg-orange-900/60 text-orange-300',
  payment: 'bg-emerald-900/60 text-emerald-300',
  witness: 'bg-cyan-900/60 text-cyan-300',
};

function getTagColor(tag: string): string {
  return tagColors[tag.trim().toLowerCase()] || 'bg-slate-700 text-slate-300';
}

function parseList(str: string | null): string[] {
  if (!str) return [];
  try {
    const parsed = JSON.parse(str);
    return Array.isArray(parsed) ? parsed : [str];
  } catch {
    return str.split(',').map(s => s.trim()).filter(Boolean);
  }
}
---
<Layout title={`${caseData.matter_name} | Client Portal`} description={`Timeline for ${caseData.matter_name}`}>
  <div class="min-h-screen bg-slate-950 relative">
    <!-- Confidential Watermark -->
    <div class="fixed bottom-4 right-4 text-xs font-mono text-red-800/30 tracking-widest uppercase select-none pointer-events-none z-50 rotate-[-12deg]">
      CONFIDENTIAL
    </div>

    <!-- Header -->
    <header class="border-b border-white/8 bg-slate-950/80 backdrop-blur-sm">
      <div class="max-w-5xl mx-auto px-6 py-5">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold text-sm">CF</div>
            <span class="text-sm text-slate-400">CaseFlare <span class="text-white/30">|</span> Client Portal</span>
          </div>
          <div class="flex items-center gap-4">
            <span class="text-sm text-slate-400">Welcome, {caseData.client_name}</span>
            <a href="/api/auth/logout" class="text-xs text-slate-500 hover:text-slate-300 transition-colors">Sign Out</a>
          </div>
        </div>
        <h1 class="text-2xl font-bold text-white mb-1">{caseData.matter_name}</h1>
        <div class="flex items-center gap-4 text-sm text-slate-400">
          <span>{caseData.client_name}</span>
          {caseData.firm_name && (
            <>
              <span class="text-white/20">|</span>
              <span>{caseData.firm_name}</span>
            </>
          )}
        </div>
      </div>
    </header>

    <!-- Stats Bar -->
    <div class="border-b border-white/5 bg-slate-900/30">
      <div class="max-w-5xl mx-auto px-6 py-3 flex items-center gap-6 text-sm text-slate-400">
        <span><strong class="text-white">{events.length}</strong> events</span>
        <span><strong class="text-white">{caseData.doc_count}</strong> documents</span>
        {dateRange && <span class="text-slate-500">{dateRange}</span>}
      </div>
    </div>

    <!-- Timeline -->
    <main class="max-w-5xl mx-auto px-6 py-10">
      {events.length === 0 ? (
        <div class="text-center py-20">
          <div class="w-16 h-16 rounded-full bg-slate-900 border border-white/8 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h2 class="text-xl text-slate-300 mb-2">Timeline is being prepared</h2>
          <p class="text-slate-500">Documents are being analyzed. Check back soon.</p>
        </div>
      ) : (
        <div class="relative">
          <!-- Timeline line -->
          <div class="absolute left-[7px] top-2 bottom-2 w-px bg-white/10"></div>

          <div class="space-y-8">
            {events.map((event) => {
              const parties = parseList(event.parties);
              const tags = parseList(event.tags);
              return (
                <div class="relative pl-10">
                  <!-- Dot -->
                  <div class="absolute left-0 top-1.5 w-[15px] h-[15px] rounded-full bg-brand-600 border-2 border-slate-950"></div>

                  <div class="bg-slate-900/50 border border-white/8 rounded-2xl p-6 hover:border-white/15 transition-colors">
                    <!-- Date -->
                    {event.event_date && (
                      <div class="text-xs font-mono text-brand-400 mb-2">{event.event_date_raw || event.event_date}</div>
                    )}

                    <!-- Title -->
                    <h3 class="text-lg font-semibold text-white mb-2">{event.title}</h3>

                    <!-- Description -->
                    <p class="text-slate-300 text-sm leading-relaxed mb-4">{event.description}</p>

                    <!-- Parties -->
                    {parties.length > 0 && (
                      <div class="flex flex-wrap gap-2 mb-3">
                        {parties.map(party => (
                          <span class="inline-block bg-slate-800 text-slate-300 text-xs px-2.5 py-1 rounded-lg">{party}</span>
                        ))}
                      </div>
                    )}

                    <!-- Tags -->
                    {tags.length > 0 && (
                      <div class="flex flex-wrap gap-2 mb-4">
                        {tags.map(tag => (
                          <span class={`inline-block text-xs px-2.5 py-0.5 rounded-full font-medium ${getTagColor(tag)}`}>{tag}</span>
                        ))}
                      </div>
                    )}

                    <!-- Source (expandable) -->
                    {(event.source_doc || event.source_quote) && (
                      <details class="group">
                        <summary class="text-xs text-slate-500 cursor-pointer hover:text-slate-400 transition-colors select-none">
                          Source: {event.source_doc}{event.source_page ? `, p.${event.source_page}` : ''}
                        </summary>
                        {event.source_quote && (
                          <blockquote class="mt-3 border-l-2 border-brand-600/40 pl-4 py-2 text-sm text-slate-400 italic bg-slate-950/50 rounded-r-lg">
                            "{event.source_quote}"
                          </blockquote>
                        )}
                      </details>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/5 py-6">
      <div class="max-w-5xl mx-auto px-6 text-center text-xs text-slate-600">
        Generated by CaseFlare — Superflare Legal Document Analysis
      </div>
    </footer>
  </div>
</Layout>
